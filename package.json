{
  "name": "clock-diagnosis-rag",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --remote",
    "dev:local": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "seed": "tsx scripts/seed.ts",
    "eval": "tsx scripts/eval.ts",
    "db:migrate:local": "wrangler d1 migrations apply clock-diagnosis-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply clock-diagnosis-db --remote"
  },
  "dependencies": {
    "hono": "^4.7.10"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.1",
    "@types/node": "^22.15.21",
    "dotenv": "^16.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "wrangler": "^4.16.1"
  }
}
